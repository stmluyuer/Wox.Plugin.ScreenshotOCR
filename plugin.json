  "Features": [
    {
      "Name": "debounce",
      "Params": {
        "IntervalMs": 200
      }
    }
  ],
  "SettingDefinitions": [
    {
      "Type": "head",
      "Value": {
        "Content": "i18n:settings_group_basic",
        "Style": {}
      }
    },
    {
      "Type": "select",
      "Value": {
        "Key": "default_ocr_provider",
        "Label": "i18n:settings_default_provider",
        "DefaultValue": "windows_app_sdk",
        "Options": [
          {
            "Label": "i18n:provider_windows_app_sdk",
            "Value": "windows_app_sdk"
          },
          { "Label": "i18n:provider_snipping_tool", "Value": "snipping_tool" },
          { "Label": "i18n:provider_wechat_qq", "Value": "wechat_qq" },
          { "Label": "i18n:provider_baidu", "Value": "baidu" },
          { "Label": "i18n:provider_youdao", "Value": "youdao" },
          { "Label": "i18n:provider_volcano", "Value": "volcano" },
          { "Label": "i18n:provider_bing", "Value": "bing" },
          { "Label": "i18n:provider_google_vision", "Value": "google_vision" },
          { "Label": "i18n:provider_llm", "Value": "llm" },
          { "Label": "i18n:provider_offline", "Value": "offline" }
        ],
        "Style": { "Width": 360 }
      }
    },
    {
      "Type": "checkbox",
      "Value": {
        "Key": "auto_translate_after_ocr",
        "Label": "i18n:settings_auto_translate",
        "DefaultValue": "false",
        "Style": { "Width": 360 }
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "translate_query_prefix",
        "Label": "i18n:settings_translate_prefix",
        "DefaultValue": "tr",
        "MaxLines": 1,
        "Style": { "Width": 220 }
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "request_timeout_ms",
        "Label": "i18n:settings_timeout",
        "DefaultValue": "15000",
        "Suffix": "ms",
        "MaxLines": 1,
        "Validators": [
          {
            "Type": "is_number",
            "Value": { "IsInteger": true, "IsFloat": false }
          }
        ],
        "Style": { "Width": 220 }
      }
    },
    {
      "Type": "newline",
      "Value": {
        "Style": {}
      }
    },
    {
      "Type": "head",
      "Value": {
        "Content": "i18n:settings_group_providers",
        "Style": {}
      }
    },
    {
      "Type": "table",
      "Value": {
        "Key": "ocr_provider_table",
        "Title": "i18n:settings_provider_table",
        "Tooltip": "i18n:settings_provider_table_tip",
        "DefaultValue": "[{\"name\":\"Windows App SDK\",\"provider\":\"windows_app_sdk\"},{\"name\":\"Snipping Tool\",\"provider\":\"snipping_tool\",\"command\":\"\"},{\"name\":\"WeChat/QQ OCR\",\"provider\":\"wechat_qq\",\"command\":\"\"},{\"name\":\"Baidu\",\"provider\":\"baidu\",\"apiKey\":\"\",\"secretKey\":\"\"},{\"name\":\"Youdao\",\"provider\":\"youdao\",\"apiKey\":\"\",\"secretKey\":\"\",\"appId\":\"\"},{\"name\":\"Volcano\",\"provider\":\"volcano\",\"apiKey\":\"\",\"secretKey\":\"\",\"region\":\"cn-north-1\"},{\"name\":\"Bing/Azure Vision\",\"provider\":\"bing\",\"apiKey\":\"\",\"baseUrl\":\"\"},{\"name\":\"Google Cloud Vision\",\"provider\":\"google_vision\",\"apiKey\":\"\",\"baseUrl\":\"https://vision.googleapis.com/v1\"},{\"name\":\"Vision LLM\",\"provider\":\"llm\",\"apiKey\":\"\",\"baseUrl\":\"https://api.openai.com/v1\",\"model\":\"gpt-4o-mini\"}]",
        "SortColumnKey": "name",
        "SortOrder": "asc",
        "MaxHeight": 320,
        "Columns": [
          {
            "Key": "name",
            "Label": "i18n:table_name",
            "Type": "text",
            "Width": 150
          },
          {
            "Key": "provider",
            "Label": "i18n:table_provider",
            "Type": "select",
            "Width": 190,
            "SelectOptions": [
              {
                "Label": "i18n:provider_windows_app_sdk",
                "Value": "windows_app_sdk"
              },
              {
                "Label": "i18n:provider_snipping_tool",
                "Value": "snipping_tool"
              },
              { "Label": "i18n:provider_wechat_qq", "Value": "wechat_qq" },
              { "Label": "i18n:provider_baidu", "Value": "baidu" },
              { "Label": "i18n:provider_youdao", "Value": "youdao" },
              { "Label": "i18n:provider_volcano", "Value": "volcano" },
              { "Label": "i18n:provider_bing", "Value": "bing" },
              {
                "Label": "i18n:provider_google_vision",
                "Value": "google_vision"
              },
              { "Label": "i18n:provider_llm", "Value": "llm" }
            ]
          },
          {
            "Key": "apiKey",
            "Label": "i18n:table_api_key",
            "Type": "text",
            "Width": 320,
            "HideInTable": true
          },
          {
            "Key": "secretKey",
            "Label": "i18n:table_secret_key",
            "Type": "text",
            "Width": 320,
            "HideInTable": true
          },
          {
            "Key": "appId",
            "Label": "i18n:table_app_id",
            "Type": "text",
            "Width": 220,
            "HideInTable": true
          },
          {
            "Key": "baseUrl",
            "Label": "i18n:table_base_url",
            "Type": "text",
            "Width": 360,
            "HideInTable": true
          },
          {
            "Key": "command",
            "Label": "i18n:table_command",
            "Type": "text",
            "Width": 360,
            "HideInTable": true
          },
          {
            "Key": "model",
            "Label": "i18n:table_model",
            "Type": "text",
            "Width": 240,
            "HideInTable": true
          },
          {
            "Key": "region",
            "Label": "i18n:table_region",
            "Type": "text",
            "Width": 180,
            "HideInTable": true
          }
        ],
        "Style": { "Width": 780 }
      }
    }
  ]
}
